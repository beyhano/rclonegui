{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rclonegui",
  "version": "0.1.4",
  "identifier": "com.beyhan.rclonegui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RClone GUI Beta v0.1.4",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "appimage"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../rclone-bin/linux/rclone": "rclone-bin/linux/rclone",
      "../rclone-bin/windows/rclone.exe": "rclone-bin/windows/rclone.exe",
      "../rclone-bin/osx-amd64/rclone": "rclone-bin/osx-amd64/rclone",
      "../rclone-bin/osx-arm64/rclone": "rclone-bin/osx-arm64/rclone"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI4QzM0NkM3RDFCQzRFQkMKUldTOFRyelJ4MGJES0ZRdTJmYWlJL3k3VWtBS2tSdFFjc1dCWVIzbDVmeGRPZTRKZnIzZDdjVG8K",
      "endpoints": [
        "https://github.com/beyhano/rclonegui/releases/latest/download/latest.json"
      ]
    }
  }
}